FROM apache/superset:latest

USER root

# Install build tools required for thrift / sasl
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libsasl2-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Hive / Thrift connectors into Superset environment
RUN uv pip install \
    pyhive \
    thrift \
    thrift-sasl

USER superset